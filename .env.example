# Environment variables for job automation

# Required: Google Gemini API key for AI matching and cover letter generation
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gmail app password for sending follow-up emails
# To create: https://support.google.com/accounts/answer/185833
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Optional: OpenAI API key (if you want to use GPT instead of Gemini)
# OPENAI_API_KEY=your_openai_api_key_here
